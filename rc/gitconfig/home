[user]
	email = hall@hey.com
	name = Miller Arlindo Hall
[color]
	ui = auto
[core]
	pager = delta
	excludesFile = ~/.gitignore
[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true  # use n and N to move between diff sections

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default
[push]
	default = simple
	autoSetupRemote = true
[alias]
	b = branch
	hash = log -n 1 --pretty=%H
	short = log --pretty=short
	when = log --pretty='%C(yellow)%h %Cblue%ad %Cgreen%an %Creset%<(50,trunc)%s' --date=short
	whend = log --decorate=short --decorate-refs-exclude='refs/tags/*' \
		--decorate-refs-exclude='refs/remotes/*/conveyor/*' \
		--decorate-refs-exclude='refs/remotes/*/gtmq*' \
		--pretty='%C(yellow)%h %Cblue%ad %Cgreen%an %Creset%s%C(auto)%(decorate)%(describe:exclude=*)' --date=short
	la = whend --decorate --graph --branches -- .
	lb = whend --decorate --graph --branches main~1..
	ln = whend --decorate --graph -n
	ll = whend --decorate --graph main~1..
	timeline = log -p --reverse main..
	names = show --name-only --pretty=""
	namese = show --name-only --pretty="" --diff-filter=d
	dnames = diff --name-only --pretty=""
	dnamese = diff --name-only --pretty="" --diff-filter=d
	adog = log --all --decorate --oneline --graph
	bdog = log --branches --decorate --oneline --graph
	stat = show --stat --pretty=""
	dstat = diff --stat
	save = !git add . && git commit --amend --no-edit
	root = rev-parse --show-toplevel
	dir = rev-parse --git-dir
[init]
	defaultBranch = main
[commit]
	gpgSign = true
