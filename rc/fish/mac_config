## Path variables
fish_add_path         /usr/local/bin
fish_add_path -a -P   $HOME/.local/bin

# Append homebrew to end of PATH instead of universal fish_add_path
fish_add_path -a -P   /opt/homebrew/bin

## Notes Shortcuts
alias 'todays-date'         'echo (date +\'%b %d, %Y\')'
alias 'notego'              'cd "$HOME/var/notes"'

alias docker                podman

alias mermaid 'npx @mermaid-js/mermaid-cli'

set -g EDITOR /opt/homebrew/bin/nvim

function pi --description 'alias for pi that sets EDITOR for opening with ctrl-g'
  EDITOR=/opt/homebrew/bin/nvim command pi -n $argv
end

alias backup-skills "ls ~/.pi/agent/skills/ | rg -v '(agent-slack-read|skill-optimizer|^\$)' | xargs -I% cp -r ~/.pi/agent/skills/% ~/dotfiles/llm/skills/"
