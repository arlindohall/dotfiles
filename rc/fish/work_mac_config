alias gcloud 'uvx gcloud'

alias kk kubectl

alias bft buildkite-failed-tests

alias gg "gt switch (jj bookmark list -r @- | head -1 | cut -d: -f1)"

function latest_commit_in_zone --argument-names zone
  git log --pretty=%H -n 1 -- (git rev-parse --show-toplevel)$zone
end

alias latest_theme_store_commit 'latest_commit_in_zone /areas/incubating/theme-store'
alias latest_app_store_commit 'latest_commit_in_zone /areas/incubating/app-store'

alias root 'dev cd // --tree root'
alias dotfiles 'cd ~/dotfiles'

set -g trees $HOME/world/trees

function __set_local_git_directory_root --on-variable PWD
  if test (git root 2>/dev/null)
    set -g root (git root)
  else
    set -eg root
  end
end
