#!/usr/bin/env bash

# pandoc-pdf - Wrapper for pandoc with LaTeX headers for emoji support
# Usage: pandoc-pdf [pandoc options] input.md -o output.pdf

HEADERS_FILE="/tmp/headers.tex"

cat >"$HEADERS_FILE" <<EOF
% Enable emoji handling via LuaLaTeX
\usepackage{fontspec}
\usepackage{luacode} % Needed for direct Lua code execution in LaTeX

% Add the font fallback chain using LuaLaTeX
% First fallback: Source Sans Pro for missing regular characters
% Second fallback: Noto Color Emoji for emoji characters
\directlua{
    luaotfload.add_fallback("fontfallback", {
        "Source Sans Pro:mode=harf;",
        "Noto Color Emoji:mode=harf;script=DFLT;"
    })
}

% Set the main font (Latin Modern Roman - LaTeX default) with fallback chain
\setmainfont{Latin Modern Roman}[RawFeature={fallback=fontfallback}]
\setsansfont{Latin Modern Sans}[RawFeature={fallback=fontfallback}]

% Optional: Load emoji-specific package if you plan to use emoji characters via name
\usepackage{emo}
EOF

CMD="pandoc --pdf-engine=lualatex -H $HEADERS_FILE $@"

echo $CMD
exec $CMD
